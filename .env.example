# Telegram
# Get a token from @BotFather. Keep the real value only in .env.
BOT_TOKEN=8772902354:AAEeGX4w9J6OZnrvi0Dq65nFuMtbfBzj2nA

# Comma-separated Telegram user IDs allowed to control the bot.
# Leave empty to allow any user. Prefer setting at least one admin in production.
ADMIN_IDS=956343475

# AI provider: grok or claude.
AI_PROVIDER=grok
GROK_API_KEY=
ANTHROPIC_API_KEY=

# Database
DATABASE_URL=sqlite+aiosqlite:///app/data/parser.db
# PostgreSQL example:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost/parser_db

# Parsing
DELAY_MIN=3
DELAY_MAX=7
REQUEST_TIMEOUT=30
RETRY_ATTEMPTS=3

# Optional shared proxy fallback for Telegram and parsers.
# COMMON_PROXY=http://user:pass@ip:port
# COMMON_PROXY=socks5://user:pass@ip:port
# Optional parser-only proxy. If empty, COMMON_PROXY is used.
# PARSER_PROXY=socks5://user:pass@ip:port
# Legacy PROXY is still accepted as PARSER_PROXY fallback only.
# PROXY=http://user:pass@ip:port
# Optional Telegram-only proxy. If empty, COMMON_PROXY is used, then direct mode.
# TELEGRAM_API_PROXY is accepted as an alias and takes priority over TELEGRAM_PROXY.
# TELEGRAM_API_PROXY=socks5://127.0.0.1:1080
# TELEGRAM_PROXY=socks5://user:pass@ip:port
# Set to 1 only when you intentionally want to discard messages queued while the bot was offline.
TELEGRAM_DROP_PENDING_UPDATES=0

# Resilience tuning
RATE_LIMIT_WB_MIN_SEC=1.5
RATE_LIMIT_WB_MAX_SEC=3.5
RATE_LIMIT_OZON_MIN_SEC=5.2
RATE_LIMIT_OZON_MAX_SEC=12.8
CIRCUIT_BLOCK_THRESHOLD=3
COOLDOWN_STEPS_MINUTES=10,20,40
ADAPTIVE_BLOCK_WINDOW_MINUTES=60
ADAPTIVE_BROWSER_BLOCK_THRESHOLD=2
ADAPTIVE_NETWORK_ERROR_THRESHOLD=3
ADAPTIVE_SAME_URL_COOLDOWN_SEC=600
ADAPTIVE_BROWSER_COOLDOWN_SEC=1200
ADAPTIVE_NETWORK_COOLDOWN_SEC=300
ADAPTIVE_COOLDOWN_STEPS=1:300,2:1800,3:7200
ADAPTIVE_MAX_COOLDOWN_SEC=21600
ADAPTIVE_PREDICTIVE_HEAT_THRESHOLD=0.9
ADAPTIVE_API_BLOCK_THRESHOLD=3
ADAPTIVE_REPUTATION_BLOCK_THRESHOLD=3
ADAPTIVE_REPUTATION_BLOCK_RATE=0.6
BLOCK_PATTERNS_JSONL=app/data/blocked_patterns.jsonl

# Logging
LOG_LEVEL=INFO
LOG_FILE=parser.log

# Ozon browser
OZON_HEADLESS=1
# Keep a persistent browser profile so manual Ozon checks/cookies survive between runs.
OZON_PROFILE_DIR=app/data/ozon_profile
# Set to 1 only if you want to skip Playwright after Ozon JSON API returns 403/429.
OZON_SKIP_BROWSER_AFTER_API_BLOCK=0

# Wildberries cloud parser. Use START_AGENT.bat option 8 or:
# py -3.11 -m app.main --deploy-wb
WB_CLOUD_FUNCTION_URL=
WB_CLOUD_FIRST=1
WB_CLOUD_FALLBACK_LOCAL=1

# Save debug artifacts when parsing fails.
# RESEARCH_ON_PARSE_FAILURE=1
